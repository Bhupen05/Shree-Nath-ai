generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StockAction {
  IN
  OUT
  ADJUST
  TRANSFER
}

enum ReferenceType {
  BILL
  MANUAL
  ADJUSTMENT
}

enum BillType {
  PURCHASE
  SALES
  RETURN
  CREDIT_NOTE
}

enum BillStatus {
  DRAFT
  CONFIRMED
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PartyType {
  CUSTOMER
  SUPPLIER
}

enum PaymentMode {
  CASH
  UPI
  BANK
  CHEQUE
  CREDIT
}

enum ReminderChannel {
  SMS
  WHATSAPP
  EMAIL
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum DemandSource {
  VOICE_AI
  MANUAL
  WEB
}

model Employee {
  id                  String         @id @default(uuid())
  empCode             String         @unique @map("emp_code")
  fullName            String         @map("full_name")
  phone               String?        @unique
  email               String?        @unique
  passwordHash        String         @map("password_hash")
  mustChangePassword  Boolean        @default(true) @map("must_change_password")
  isActive            Boolean        @default(true) @map("is_active")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  employeeRoles       EmployeeRole[]
  activityLogs        ActivityLog[]
  billsCreated        Bill[]
  paymentsReceived    BillPayment[]
  stockEntriesAdded   StockEntry[]
  stockLogsPerformed  StockLog[]

  @@map("employees")
}

model Role {
  id            String         @id @default(uuid())
  name          String         @unique
  permissions   Json?
  createdAt     DateTime       @default(now()) @map("created_at")
  employeeRoles EmployeeRole[]

  @@map("roles")
}

model EmployeeRole {
  employeeId String   @map("employee_id")
  roleId     String   @map("role_id")
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([employeeId, roleId])
  @@map("employee_roles")
}

model Product {
  id            String           @id @default(uuid())
  sku           String           @unique
  name          String
  description   String?
  category      String?
  brand         String?
  unit          String           @default("pcs")
  sellingPrice  Decimal          @map("selling_price") @db.Decimal(12, 2)
  costPrice     Decimal?         @map("cost_price") @db.Decimal(12, 2)
  reorderLevel  Int              @default(5) @map("reorder_level")
  barcode       String?          @unique
  imageUrl      String?          @map("image_url")
  isActive      Boolean          @default(true) @map("is_active")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  vehicles      ProductVehicle[]
  stockEntries  StockEntry[]
  stockLogs     StockLog[]
  billItems     BillItem[]
  demandLogs    DemandLog[]

  @@map("products")
}

model ProductVehicle {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  make         String
  model        String
  yearFrom     Int?     @map("year_from")
  yearTo       Int?     @map("year_to")
  notes        String?
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_vehicles")
}

model Location {
  id          String       @id @default(uuid())
  room        String
  cabinet     String
  section     String
  description String?
  stockEntries StockEntry[]

  @@unique([room, cabinet, section])
  @@map("locations")
}

model Supplier {
  id           String       @id @default(uuid())
  name         String
  contactName  String?      @map("contact_name")
  phone        String?
  email        String?
  address      String?
  gstin        String?
  createdAt    DateTime     @default(now()) @map("created_at")
  stockEntries StockEntry[]
  bills        Bill[]

  @@map("suppliers")
}

model StockEntry {
  id            String      @id @default(uuid())
  productId     String      @map("product_id")
  locationId    String      @map("location_id")
  supplierId    String?     @map("supplier_id")
  billReference String?     @map("bill_reference")
  batchNumber   String?     @map("batch_number")
  quantity      Int
  costPrice     Decimal?    @map("cost_price") @db.Decimal(12, 2)
  receivedDate  DateTime    @map("received_date") @db.Date
  expiryDate    DateTime?   @map("expiry_date") @db.Date
  addedById     String?     @map("added_by")
  billDocUrl    String?     @map("bill_doc_url")
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  product       Product     @relation(fields: [productId], references: [id])
  location      Location    @relation(fields: [locationId], references: [id])
  supplier      Supplier?   @relation(fields: [supplierId], references: [id])
  addedBy       Employee?   @relation(fields: [addedById], references: [id])
  stockLogs     StockLog[]
  billItems     BillItem[]

  @@map("stock_entries")
}

model StockLog {
  id             String        @id @default(uuid())
  stockEntryId   String        @map("stock_entry_id")
  productId      String        @map("product_id")
  action         StockAction
  quantityChange Int           @map("quantity_change")
  balanceAfter   Int?          @map("balance_after")
  referenceType  ReferenceType @map("reference_type")
  referenceId    String?       @map("reference_id")
  performedById  String?       @map("performed_by")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  stockEntry     StockEntry    @relation(fields: [stockEntryId], references: [id])
  product        Product       @relation(fields: [productId], references: [id])
  performedBy    Employee?     @relation(fields: [performedById], references: [id])

  @@map("stock_logs")
}

model Customer {
  id          String   @id @default(uuid())
  name        String
  phone       String?
  email       String?
  address     String?
  gstin       String?
  creditLimit Decimal  @default(0) @map("credit_limit") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  bills       Bill[]

  @@map("customers")
}

model Bill {
  id           String            @id @default(uuid())
  billNumber   String            @unique @map("bill_number")
  billType     BillType          @map("bill_type")
  status       BillStatus        @default(DRAFT)
  customerId   String?           @map("customer_id")
  supplierId   String?           @map("supplier_id")
  partyType    PartyType         @map("party_type")
  billDate     DateTime          @map("bill_date") @db.Date
  dueDate      DateTime?         @map("due_date") @db.Date
  subtotal     Decimal           @db.Decimal(12, 2)
  discount     Decimal           @default(0) @db.Decimal(12, 2)
  taxAmount    Decimal           @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount  Decimal           @map("total_amount") @db.Decimal(12, 2)
  paidAmount   Decimal           @default(0) @map("paid_amount") @db.Decimal(12, 2)
  notes        String?
  createdById  String?           @map("created_by")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  customer     Customer?         @relation(fields: [customerId], references: [id])
  supplier     Supplier?         @relation(fields: [supplierId], references: [id])
  createdBy    Employee?         @relation(fields: [createdById], references: [id])
  billItems    BillItem[]
  billPayments BillPayment[]
  reminders    PaymentReminder[]

  @@map("bills")
}

model BillItem {
  id           String     @id @default(uuid())
  billId       String     @map("bill_id")
  productId    String     @map("product_id")
  stockEntryId String?    @map("stock_entry_id")
  quantity     Int
  unitPrice    Decimal    @map("unit_price") @db.Decimal(12, 2)
  discountPct  Decimal    @default(0) @map("discount_pct") @db.Decimal(5, 2)
  taxPct       Decimal    @default(0) @map("tax_pct") @db.Decimal(5, 2)
  lineTotal    Decimal    @map("line_total") @db.Decimal(12, 2)
  bill         Bill       @relation(fields: [billId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id])
  stockEntry   StockEntry? @relation(fields: [stockEntryId], references: [id])

  @@map("bill_items")
}

model BillPayment {
  id           String      @id @default(uuid())
  billId        String      @map("bill_id")
  amount        Decimal     @db.Decimal(12, 2)
  paymentMode   PaymentMode @map("payment_mode")
  referenceNo   String?     @map("reference_no")
  paymentDate   DateTime    @map("payment_date") @db.Date
  receivedById  String?     @map("received_by")
  notes         String?
  bill          Bill        @relation(fields: [billId], references: [id], onDelete: Cascade)
  receivedBy    Employee?   @relation(fields: [receivedById], references: [id])

  @@map("bill_payments")
}

model PaymentReminder {
  id           String         @id @default(uuid())
  billId        String         @map("bill_id")
  channel       ReminderChannel
  scheduledAt   DateTime       @map("scheduled_at")
  sentAt        DateTime?      @map("sent_at")
  status        ReminderStatus @default(PENDING)
  messageBody   String         @map("message_body")
  responseLog   Json?          @map("response_log")
  bill          Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@map("payment_reminders")
}

model ActivityLog {
  id         String    @id @default(uuid())
  employeeId String?   @map("employee_id")
  action     String
  entityType String?   @map("entity_type")
  entityId   String?   @map("entity_id")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  employee   Employee? @relation(fields: [employeeId], references: [id])

  @@map("activity_logs")
}

model DemandLog {
  id           String       @id @default(uuid())
  source       DemandSource
  queryText    String       @map("query_text")
  productId    String?      @map("product_id")
  vehicleMake  String?      @map("vehicle_make")
  vehicleModel String?      @map("vehicle_model")
  quantityReq  Int?         @map("quantity_req")
  fulfilled    Boolean      @default(false)
  callerPhone  String?      @map("caller_phone")
  createdAt    DateTime     @default(now()) @map("created_at")
  product      Product?     @relation(fields: [productId], references: [id])

  @@map("demand_logs")
}
